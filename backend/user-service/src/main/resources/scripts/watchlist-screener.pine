// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  AXIOM ULTIMATE WATCHLIST SCREENER v4.0                                ║
// ║  Monitor 40 stocks simultaneously — finds 90%+ confidence signals      ║
// ║  Combines: SMC + ICT + MTF + 15 indicators + Patterns + Fundamentals   ║
// ║                                                                          ║
// ║  HOW TO USE:                                                             ║
// ║  1. Add to TradingView Pine Editor → Add to Chart                       ║
// ║  2. Go to Pine Screener (Premium+) → select this indicator              ║
// ║  3. Select your watchlist → Scan                                         ║
// ║  4. Filter: SCORE >= 80 for high-confidence signals                      ║
// ╚══════════════════════════════════════════════════════════════════════════╝
//@version=5
indicator("AXIOM Ultimate Screener v4.0", overlay=false, max_bars_back=500)

// ══════════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════════
grp_mtf = "═══ MULTI-TIMEFRAME ═══"
htf1    = input.timeframe("D",   "HTF 1 (Bias)",     group=grp_mtf)
htf2    = input.timeframe("240", "HTF 2 (Zones)",    group=grp_mtf)
ltf1    = input.timeframe("60",  "LTF (Entry)",      group=grp_mtf)

grp_ind = "═══ INDICATOR SETTINGS ═══"
ema_s   = input.int(9,   "EMA Fast",  group=grp_ind)
ema_m   = input.int(21,  "EMA Mid",   group=grp_ind)
ema_l   = input.int(50,  "EMA Slow",  group=grp_ind)
ema_t   = input.int(200, "EMA Trend", group=grp_ind)
rsi_len = input.int(14,  "RSI",       group=grp_ind)
st_atr  = input.int(10,  "ST ATR",    group=grp_ind)
st_fac  = input.float(3.0,"ST Factor",group=grp_ind)
adx_len = input.int(14,  "ADX",       group=grp_ind)
bb_len  = input.int(20,  "BB Length", group=grp_ind)
kc_len  = input.int(20,  "KC Length", group=grp_ind)
kc_mult = input.float(1.5,"KC Mult",  group=grp_ind)
cmf_len = input.int(20,  "CMF",       group=grp_ind)
vol_ma  = input.int(20,  "Volume MA", group=grp_ind)

grp_thr = "═══ THRESHOLDS ═══"
bull_th = input.int(75, "Bull Score (0-100)", group=grp_thr)
bear_th = input.int(25, "Bear Score (0-100)", group=grp_thr)
min_adx = input.int(20, "Min ADX for trend",  group=grp_thr)
min_vol = input.float(1.3, "Min Vol Mult",     group=grp_thr)

// ══════════════════════════════════════════════════════════════════
// ── MULTI-TIMEFRAME DATA ──────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════
// HTF1 (Daily bias)
[htf1_close, htf1_high, htf1_low, htf1_open, htf1_vol] =
    request.security(syminfo.tickerid, htf1,
        [close[1], high[1], low[1], open[1], volume[1]],
        lookahead=barmerge.lookahead_on)

htf1_ema50  = request.security(syminfo.tickerid, htf1, ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
htf1_ema200 = request.security(syminfo.tickerid, htf1, ta.ema(close, 200), lookahead=barmerge.lookahead_off)
[htf1_st, htf1_stdir] = request.security(syminfo.tickerid, htf1, ta.supertrend(st_fac, st_atr), lookahead=barmerge.lookahead_off)
htf1_rsi    = request.security(syminfo.tickerid, htf1, ta.rsi(close, rsi_len), lookahead=barmerge.lookahead_off)
[htf1_macdl, htf1_macds, htf1_macdh] = request.security(syminfo.tickerid, htf1, ta.macd(close,12,26,9), lookahead=barmerge.lookahead_off)

// HTF2 (4H zones)
[htf2_close, htf2_high, htf2_low] =
    request.security(syminfo.tickerid, htf2,
        [close[1], high[1], low[1]],
        lookahead=barmerge.lookahead_on)

htf2_ema50  = request.security(syminfo.tickerid, htf2, ta.ema(close, 50),  lookahead=barmerge.lookahead_off)
[htf2_st, htf2_stdir] = request.security(syminfo.tickerid, htf2, ta.supertrend(st_fac, st_atr), lookahead=barmerge.lookahead_off)
htf2_rsi    = request.security(syminfo.tickerid, htf2, ta.rsi(close, rsi_len), lookahead=barmerge.lookahead_off)
[htf2_macdl, htf2_macds, htf2_macdh] = request.security(syminfo.tickerid, htf2, ta.macd(close,12,26,9), lookahead=barmerge.lookahead_off)

// LTF (1H entry)
ltf_close   = request.security(syminfo.tickerid, ltf1, close,  lookahead=barmerge.lookahead_off)
ltf_ema21   = request.security(syminfo.tickerid, ltf1, ta.ema(close, 21), lookahead=barmerge.lookahead_off)
ltf_rsi     = request.security(syminfo.tickerid, ltf1, ta.rsi(close, rsi_len), lookahead=barmerge.lookahead_off)
[ltf_macdl, ltf_macds, ltf_macdh] = request.security(syminfo.tickerid, ltf1, ta.macd(close,12,26,9), lookahead=barmerge.lookahead_off)
[ltf_st, ltf_stdir] = request.security(syminfo.tickerid, ltf1, ta.supertrend(st_fac, st_atr), lookahead=barmerge.lookahead_off)

// ══════════════════════════════════════════════════════════════════
// ── CURRENT TIMEFRAME INDICATORS ─────────────────────────────────
// ══════════════════════════════════════════════════════════════════
e9   = ta.ema(close, ema_s)
e21  = ta.ema(close, ema_m)
e50  = ta.ema(close, ema_l)
e200 = ta.ema(close, ema_t)
vwap_v = ta.vwap(hlc3)

[st_line, st_dir]   = ta.supertrend(st_fac, st_atr)
[st2_line, st2_dir] = ta.supertrend(2.0, 7)   // fast ST
st_bull    = st_dir < 0
st2_bull   = st2_dir < 0
st_flip_b  = st_bull and not st_bull[1]
st_flip_s  = not st_bull and st_bull[1]

rsi_v = ta.rsi(close, rsi_len)
[macd_l, macd_s, macd_h] = ta.macd(close, 12, 26, 9)
stoch_k = ta.stoch(close, high, low, 14)
stoch_d = ta.ema(stoch_k, 3)
will_r  = -100 * (ta.highest(high,14) - close) / (ta.highest(high,14) - ta.lowest(low,14))
cci_v   = (close - ta.sma(close, 20)) / (0.015 * ta.dev(close, 20))

// Bollinger + Keltner Squeeze
[bb_mid, bb_up, bb_lo] = ta.bb(close, bb_len, 2.0)
bb_width  = (bb_up - bb_lo) / bb_mid * 100
kc_mid    = ta.ema(close, kc_len)
kc_atr    = ta.atr(kc_len) * kc_mult
kc_up     = kc_mid + kc_atr
kc_lo     = kc_mid - kc_atr
sqz_on    = bb_up < kc_up and bb_lo > kc_lo   // squeeze active
sqz_fired = not sqz_on and sqz_on[1]           // squeeze just released

// ADX
[dmi_p, dmi_n, adx_v] = ta.dmi(adx_len, adx_len)
strong_trend = adx_v > min_adx
trend_up_adx = dmi_p > dmi_n
trend_dn_adx = dmi_n > dmi_p

// Volume
vol_avg   = ta.sma(volume, vol_ma)
vol_spike = volume > vol_avg * 2.0
vol_high  = volume > vol_avg * min_vol
rvol      = volume / math.max(vol_avg, 1)

// CMF + OBV
mf_m  = (high != low) ? ((close - low) - (high - close)) / (high - low) : 0.0
cmf_v = ta.sma(nz(mf_m * volume), cmf_len) / math.max(ta.sma(volume, cmf_len), 1)
obv_v = ta.obv
obv_bull = obv_v > ta.ema(obv_v, 20)

// ATR
atr_v   = ta.atr(14)
atr_pct = atr_v / close * 100

// AROON
aroon_up = 100.0 * (25 - ta.highestbars(high, 25)) / 25
aroon_dn = 100.0 * (25 - ta.lowestbars(low,  25)) / 25

// Parabolic SAR
sar_v    = ta.sar(0.02, 0.02, 0.2)
sar_bull = close > sar_v

// ══════════════════════════════════════════════════════════════════
// ── SMC / ICT CONCEPTS ───────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════
// Swing points
ph = ta.pivothigh(high, 5, 5)
pl = ta.pivotlow(low, 5, 5)

// Last swing highs/lows
var float last_ph1 = na, var float last_ph2 = na
var float last_pl1 = na, var float last_pl2 = na
if not na(ph)
    last_ph2 := last_ph1
    last_ph1 := ph
if not na(pl)
    last_pl2 := last_pl1
    last_pl1 := pl

// Market structure: Higher Highs + Higher Lows = uptrend
hh_hl = not na(last_ph1) and not na(last_ph2) and
        not na(last_pl1) and not na(last_pl2) and
        last_ph1 > last_ph2 and last_pl1 > last_pl2

lh_ll = not na(last_ph1) and not na(last_ph2) and
        not na(last_pl1) and not na(last_pl2) and
        last_ph1 < last_ph2 and last_pl1 < last_pl2

// Break of Structure (BOS)
bos_bull = not na(last_ph1) and ta.crossover(close, last_ph1)
bos_bear = not na(last_pl1) and ta.crossunder(close, last_pl1)

// Liquidity sweep (stop hunt before reversal)
liq_sweep_bull = low < last_pl1 and close > last_pl1 and not na(last_pl1)
liq_sweep_bear = high > last_ph1 and close < last_ph1 and not na(last_ph1)

// Fair Value Gap (FVG) — 3-bar imbalance
bull_fvg = low[0] > high[2] and close[1] > open[1]   // bullish imbalance
bear_fvg = high[0] < low[2] and close[1] < open[1]   // bearish imbalance

// Order Block detection (last bearish candle before bull move, vice versa)
ob_bull = close[1] < open[1] and close > high[1]     // last bearish candle engulfed
ob_bear = close[1] > open[1] and close < low[1]      // last bullish candle engulfed

// Change of Character (CHoCH) — trend reversal signal
choch_bull = lh_ll and bos_bull   // was downtrend, now broke structure up
choch_bear = hh_hl and bos_bear   // was uptrend, now broke structure down

// Premium / Discount zone (50% of last major swing)
swing_high = not na(last_ph1) ? last_ph1 : high
swing_low  = not na(last_pl1) ? last_pl1 : low
equilibrium = (swing_high + swing_low) / 2
in_discount = close < equilibrium   // cheap zone — look for longs
in_premium  = close > equilibrium   // expensive zone — look for shorts

// ICT Killzone detection (NY open 9:30-11 EST = high probability)
ny_open_hour = 9
ny_close_hour = 11
in_killzone = (hour >= ny_open_hour and hour < ny_close_hour) or
              (hour >= 2 and hour < 5)   // London open

// Previous day high/low (key S/R)
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
above_pdh = close > pdh
below_pdl = close < pdl

// ══════════════════════════════════════════════════════════════════
// ── CANDLESTICK PATTERNS ─────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════
body     = math.abs(close - open)
rng      = high - low
up_bar   = close > open
dn_bar   = close < open
lo_wick  = math.min(open, close) - low
hi_wick  = high - math.max(open, close)
is_doji  = body < rng * 0.08

bull_engulf    = up_bar and dn_bar[1] and close > open[1] and open < close[1] and body > body[1]
bear_engulf    = dn_bar and up_bar[1] and close < open[1] and open > close[1] and body > body[1]
bull_hammer    = lo_wick > body * 2.5 and hi_wick < body * 0.5
bear_shoot     = hi_wick > body * 2.5 and lo_wick < body * 0.5
morning_star   = dn_bar[2] and is_doji[1] and up_bar and close > (open[2]+close[2])/2
evening_star   = up_bar[2] and is_doji[1] and dn_bar and close < (open[2]+close[2])/2
three_bull     = up_bar and up_bar[1] and up_bar[2] and close>close[1] and close[1]>close[2] and body>rng*0.5
three_bear     = dn_bar and dn_bar[1] and dn_bar[2] and close<close[1] and close[1]<close[2] and body>rng*0.5
bull_marubozu  = up_bar and lo_wick < body*0.05 and hi_wick < body*0.05 and body > rng*0.8
bear_marubozu  = dn_bar and lo_wick < body*0.05 and hi_wick < body*0.05 and body > rng*0.8

// Inside bar (range compression before breakout)
inside_bar     = high < high[1] and low > low[1]
inside_bar_bull= inside_bar and close > open
inside_bar_bear= inside_bar and close < open

// ══════════════════════════════════════════════════════════════════
// ── DIVERGENCE DETECTION ─────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════
rsi_bull_div = low < low[5]  and rsi_v > rsi_v[5] and rsi_v < 50   // hidden bull div
rsi_bear_div = high > high[5] and rsi_v < rsi_v[5] and rsi_v > 50  // hidden bear div
macd_bull_div = low < low[8]  and macd_h > macd_h[8] and macd_h < 0
macd_bear_div = high > high[8] and macd_h < macd_h[8] and macd_h > 0
obv_bull_div  = close < close[10] and obv_v > obv_v[10]
obv_bear_div  = close > close[10] and obv_v < obv_v[10]

// ══════════════════════════════════════════════════════════════════
// ── SCORING SYSTEM (0-100) ────────────────────────────────────────
// ══════════════════════════════════════════════════════════════════
// Each factor scores +/- points. Sum normalized to 0-100.

score = 0

// ── A. MULTI-TIMEFRAME ALIGNMENT (30 pts max) ────────────────────
// Daily bias (most important)
htf1_bull_bias = htf1_close > htf1_ema50 and htf1_ema50 > htf1_ema200 and htf1_stdir < 0
htf1_bear_bias = htf1_close < htf1_ema50 and htf1_ema50 < htf1_ema200 and htf1_stdir > 0

score += htf1_bull_bias ? 15 : 0
score += htf1_bear_bias ? -15 : 0
score += htf1_rsi > 50  ? 3 : -3
score += htf1_macdh > 0 ? 3 : -3

// 4H intermediate
htf2_bull = htf2_close > htf2_ema50 and htf2_stdir < 0
htf2_bear = htf2_close < htf2_ema50 and htf2_stdir > 0
score += htf2_bull ? 5 : 0
score += htf2_bear ? -5 : 0
score += htf2_rsi > 50  ? 2 : -2
score += htf2_macdh > 0 ? 2 : -2

// ── B. CURRENT TF TREND (20 pts max) ─────────────────────────────
score += close > e9   ? 2 : -2
score += close > e21  ? 2 : -2
score += close > e50  ? 3 : -3
score += close > e200 ? 4 : -4
score += e9 > e21     ? 2 : -2
score += e50 > e200   ? 2 : -2
score += ta.crossover(e50, e200)  ? 3 : 0    // golden cross
score += ta.crossunder(e50, e200) ? -3 : 0   // death cross
score += st_bull  ? 3 : -3
score += st2_bull ? 2 : -2

// ── C. MOMENTUM (15 pts max) ──────────────────────────────────────
score += rsi_v > 50 and rsi_v < 70  ? 4 : 0
score += rsi_v < 50 and rsi_v > 30  ? -2 : 0
score += rsi_v >= 70 ? -1 : 0    // overbought caution
score += rsi_v <= 30 ? 2  : 0    // oversold (potential bounce)
score += rsi_bull_div ? 3 : 0
score += rsi_bear_div ? -3 : 0
score += macd_h > 0  ? 4 : -4
score += macd_h > macd_h[1] ? 2 : -1   // histogram expanding
score += macd_bull_div ? 3 : 0
score += macd_bear_div ? -3 : 0

// ── D. VOLUME CONFIRMATION (10 pts max) ──────────────────────────
score += cmf_v >  0.15 ? 4 : cmf_v >  0.05 ? 2 : 0
score += cmf_v < -0.15 ? -4 : cmf_v < -0.05 ? -2 : 0
score += obv_bull  ? 3 : -3
score += obv_bull_div ? 2 : 0
score += obv_bear_div ? -2 : 0
score += vol_spike and close > open ? 3 : 0
score += vol_spike and close < open ? -3 : 0

// ── E. SMC / MARKET STRUCTURE (10 pts max) ───────────────────────
score += hh_hl      ?  6 : 0
score += lh_ll      ? -6 : 0
score += bos_bull   ?  4 : 0
score += bos_bear   ? -4 : 0
score += choch_bull ?  3 : 0
score += choch_bear ? -3 : 0
score += liq_sweep_bull ?  2 : 0   // liquidity sweep + reversal
score += liq_sweep_bear ? -2 : 0
score += in_discount ?  1 : 0     // buying in discount zone
score += in_premium  ? -1 : 0     // buying in premium zone (risky)

// ── F. CANDLESTICK PATTERNS (5 pts max) ──────────────────────────
score += bull_engulf    ?  3 : 0
score += bear_engulf    ? -3 : 0
score += morning_star   ?  3 : 0
score += evening_star   ? -3 : 0
score += three_bull     ?  4 : 0
score += three_bear     ? -4 : 0
score += bull_hammer    ?  2 : 0
score += bear_shoot     ? -2 : 0
score += bull_marubozu  ?  2 : 0
score += bear_marubozu  ? -2 : 0
score += ob_bull        ?  2 : 0
score += ob_bear        ? -2 : 0

// ── G. VOLATILITY SETUP (5 pts max) ──────────────────────────────
score += sqz_on    ?  3 : 0     // squeeze = breakout coming
score += sqz_fired ?  2 : 0     // squeeze just released
score += adx_v > 30 and trend_up_adx ? 4 : 0
score += adx_v > 30 and trend_dn_adx ? -4 : 0
score += not strong_trend ? -2 : 0   // ranging = less confidence
score += sar_bull  ?  2 : -2
score += aroon_up > aroon_dn ?  2 : -2

// ── H. FVG / ICT CONCEPTS (5 pts max) ────────────────────────────
score += bull_fvg  ?  3 : 0
score += bear_fvg  ? -3 : 0
score += above_pdh ?  2 : 0     // broke previous day high
score += below_pdl ? -2 : 0     // broke previous day low
score += in_killzone ? 1 : 0    // ICT killzone timing

// ── NORMALIZE TO 0-100 ────────────────────────────────────────────
// Theoretical range ≈ -110 to +110 → map to 0-100
final_score = math.round((score + 110) / 220 * 100)
final_score := math.max(0, math.min(100, final_score))

// ── CONFIDENCE BOOST ──────────────────────────────────────────────
// Boost when multiple rare high-confidence signals align
high_conf_bull = (bos_bull or choch_bull) and htf1_bull_bias and htf2_bull and
                 rsi_v > 50 and macd_h > 0 and cmf_v > 0 and
                 (bull_engulf or morning_star or three_bull or ob_bull)

high_conf_bear = (bos_bear or choch_bear) and htf1_bear_bias and htf2_bear and
                 rsi_v < 50 and macd_h < 0 and cmf_v < 0 and
                 (bear_engulf or evening_star or three_bear or ob_bear)

// Squeeze breakout confirmation (high probability)
sqz_bull_break = sqz_fired and close > bb_mid and macd_h > 0 and
                 htf1_bull_bias and vol_high

sqz_bear_break = sqz_fired and close < bb_mid and macd_h < 0 and
                 htf1_bear_bias and vol_high

// Divergence + reversal combo
div_bull_rev = (rsi_bull_div or macd_bull_div or obv_bull_div) and
               (bull_engulf or bull_hammer or morning_star or ob_bull) and
               liq_sweep_bull

div_bear_rev = (rsi_bear_div or macd_bear_div or obv_bear_div) and
               (bear_engulf or bear_shoot or evening_star or ob_bear) and
               liq_sweep_bear

// Apply confidence boost (max 10 pts)
boost = 0
boost += high_conf_bull ? 8 : 0
boost += high_conf_bear ? -8 : 0
boost += sqz_bull_break ? 5 : 0
boost += sqz_bear_break ? -5 : 0
boost += div_bull_rev   ? 4 : 0
boost += div_bear_rev   ? -4 : 0

final_score := math.max(0, math.min(100, final_score + boost))

// ── VERDICT ───────────────────────────────────────────────────────
verdict = final_score >= 85 ? "STRONG BULL ★★★★★" :
          final_score >= 75 ? "MILD BULL  ★★★★" :
          final_score >= 60 ? "WEAK BULL  ★★★" :
          final_score >= 45 ? "NEUTRAL    ★★" :
          final_score >= 35 ? "WEAK BEAR  ★★" :
          final_score >= 25 ? "MILD BEAR  ★★★★" :
                              "STRONG BEAR ★★★★★"

// ── BUY / SELL SIGNAL (≥90% confidence) ──────────────────────────
buy_signal  = final_score >= bull_th and
              (high_conf_bull or sqz_bull_break or
               (st_flip_b and htf1_bull_bias and vol_high))

sell_signal = final_score <= bear_th and
              (high_conf_bear or sqz_bear_break or
               (st_flip_s and htf1_bear_bias and vol_high))

// ── PLOTS (for Pine Screener export) ─────────────────────────────
// These plot() calls are what Pine Screener reads as filterable columns
plot(final_score, "Score",      color=final_score>=bull_th ? color.green : final_score<=bear_th ? color.red : color.gray)
plot(rsi_v,       "RSI",        color=color.blue)
plot(adx_v,       "ADX",        color=color.orange)
plot(cmf_v * 100, "CMF%",       color=cmf_v>0 ? color.green : color.red)
plot(rvol,        "RVol",       color=color.purple)
plot(buy_signal  ? 1 : 0, "BUY_SIGNAL",  color=color.lime)
plot(sell_signal ? 1 : 0, "SELL_SIGNAL", color=color.red)
plot(sqz_on  ? 1 : 0, "SQUEEZE",     color=color.yellow)
plot(hh_hl   ? 1 : 0, "HH_HL",       color=color.teal)
plot(htf1_bull_bias ? 1 : 0, "DAILY_BULL", color=color.green)

// ── VISUAL ON CHART ────────────────────────────────────────────────
// Score histogram
hline(bull_th, "Bull Threshold", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(bear_th, "Bear Threshold", color=color.new(color.red,   50), linestyle=hline.style_dashed)
hline(50,      "Neutral",        color=color.new(color.gray,  70), linestyle=hline.style_dotted)

score_color = final_score >= 85 ? #00c853 :
              final_score >= 75 ? #69f0ae :
              final_score >= 60 ? #b2ff59 :
              final_score >= 45 ? #90a4ae :
              final_score >= 35 ? #ffab40 :
              final_score >= 25 ? #ff7043 :
                                  #d32f2f

plot(final_score, "AXIOM Score", color=score_color, linewidth=3, style=plot.style_histogram)
plot(final_score, "Score Line",  color=color.new(color.white, 60), linewidth=1)

// Signal markers (on histogram pane)
plotshape(buy_signal,  "BUY",  shape.labelup,   location.bottom, color.new(color.green, 0), text="BUY",  textcolor=color.white, size=size.small)
plotshape(sell_signal, "SELL", shape.labeldown, location.top,    color.new(color.red,   0), text="SELL", textcolor=color.white, size=size.small)

// Score label
if barstate.islast
    label.new(bar_index, final_score,
        str.tostring(final_score) + "/100\n" + verdict +
        (sqz_on ? "\n⚡ SQUEEZE" : "") +
        (hh_hl  ? "\n↗ HH+HL"  : lh_ll ? "\n↘ LH+LL" : "") +
        (high_conf_bull ? "\n★ HIGH CONF BULL" : high_conf_bear ? "\n★ HIGH CONF BEAR" : "") +
        (div_bull_rev   ? "\n◆ DIVERGENCE REVERSAL" : div_bear_rev ? "\n◆ DIV REVERSAL" : ""),
        color=score_color, textcolor=color.white,
        style=label.style_label_left, size=size.normal)

// ── ALERTS ────────────────────────────────────────────────────────
action_str  = buy_signal ? "BUY" : sell_signal ? "SELL" : "NEUTRAL"
pattern_str = high_conf_bull ? "High Conf Bull" : choch_bull ? "CHoCH Bull" : bos_bull ? "BOS Bull" :
              high_conf_bear ? "High Conf Bear" : choch_bear ? "CHoCH Bear" : bos_bear ? "BOS Bear" :
              sqz_fired ? "Squeeze Break" : div_bull_rev ? "Div Reversal" : bull_fvg ? "FVG Bull" : "None"

alert_json = '{"ticker":"' + syminfo.ticker +
    '","action":"' + action_str +
    '","score":' + str.tostring(final_score) +
    ',"verdict":"' + verdict +
    '","price":' + str.tostring(math.round(close*100)/100) +
    ',"rsi":' + str.tostring(math.round(rsi_v*10)/10) +
    ',"macd_hist":' + str.tostring(math.round(macd_h*1000)/1000) +
    ',"adx":' + str.tostring(math.round(adx_v*10)/10) +
    ',"cmf":' + str.tostring(math.round(cmf_v*1000)/1000) +
    ',"rvol":' + str.tostring(math.round(rvol*100)/100) +
    ',"pattern":"' + pattern_str +
    '","timeframe":"' + timeframe.period +
    '","htf_daily_bull":' + str.tostring(htf1_bull_bias) +
    ',"hh_hl":' + str.tostring(hh_hl) +
    ',"squeeze":' + str.tostring(sqz_on) +
    ',"high_conf":' + str.tostring(high_conf_bull or high_conf_bear) +
    ',"bos":' + str.tostring(bos_bull or bos_bear) +
    ',"fvg":' + str.tostring(bull_fvg or bear_fvg) +
    ',"div":' + str.tostring(rsi_bull_div or macd_bull_div or rsi_bear_div or macd_bear_div) + '}'

alertcondition(buy_signal,          "AXIOM BUY ≥" + str.tostring(bull_th),  alert_json)
alertcondition(sell_signal,         "AXIOM SELL ≤" + str.tostring(bear_th), alert_json)
alertcondition(high_conf_bull,      "HIGH CONF BULL",    alert_json)
alertcondition(high_conf_bear,      "HIGH CONF BEAR",    alert_json)
alertcondition(sqz_bull_break,      "SQUEEZE BULL BREAK",alert_json)
alertcondition(sqz_bear_break,      "SQUEEZE BEAR BREAK",alert_json)
alertcondition(div_bull_rev,        "DIV BULL REVERSAL", alert_json)
alertcondition(div_bear_rev,        "DIV BEAR REVERSAL", alert_json)
alertcondition(choch_bull,          "CHoCH BULL",        alert_json)
alertcondition(choch_bear,          "CHoCH BEAR",        alert_json)
